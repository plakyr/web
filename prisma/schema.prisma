generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AdminUser {
  id            String   @id @default(uuid())
  username      String   @unique
  password_hash String
  role          String   @default("admin")
  created_at    DateTime @default(now())
}

model Event {
  id            String   @id @default(uuid())
  name          String
  date          DateTime
  is_active     Boolean  @default(true)
  layouts       VenueLayout[]
  participants  Participant[]
  systemState   SystemState?
  chatMessages  ChatMessage[]
  adminLogs     AdminLog[]
  sessionColors SessionColor[]
}

model VenueLayout {
  id            String   @id @default(uuid())
  event_id      String
  event         Event    @relation(fields: [event_id], references: [id])
  rows          Int
  cols          Int
  seats         Seat[]
}

model Seat {
  id            String   @id @default(uuid())
  layout_id     String
  layout        VenueLayout @relation(fields: [layout_id], references: [id])
  row           Int
  col           Int
  status        String   // "EMPTY", "RESERVED", "AUTO_ASSIGNED", "LOCKED"
  assigned_to   String?  // Participant ID
  session_id    String?  // The session this seat was reserved in
  updated_at    DateTime @updatedAt
  
  @@unique([layout_id, row, col])
}

model Participant {
  id                  String   @id @default(uuid())
  event_id            String
  event               Event    @relation(fields: [event_id], references: [id])
  session_id          String
  name                String
  phone_last4         String
  unique_code         String?  // 동명이인+동일번호 발생 시 보조 식별자
  turn_order          Int
  allowed_start_time  DateTime?
  allowed_end_time    DateTime?
  seat_id             String?  @unique // 할당된 좌석
  session_token       String?  // 중복 로그인 방지용 단일 세션 토큰
  is_final            Boolean  @default(false)
  turn_status         String   @default("WAITING") // "WAITING", "ACTIVE", "COMPLETED", "EXPIRED"
}

model SessionColor {
  id            String   @id @default(uuid())
  event_id      String
  event         Event    @relation(fields: [event_id], references: [id])
  session_id    String
  color         String
  start_time    String?
  end_time      String?
  
  @@unique([event_id, session_id])
}

model SystemState {
  id                      String   @id @default(uuid())
  event_id                String   @unique
  event                   Event    @relation(fields: [event_id], references: [id])
  is_frozen               Boolean  @default(false)
  frozen_reason           String?
  frozen_at               DateTime?
  current_turn_order      Int      @default(1)
  current_turn_start_time DateTime @default(now())
}

model ChatMessage {
  id            String   @id @default(uuid())
  event_id      String
  event         Event    @relation(fields: [event_id], references: [id])
  sender_type   String   // "ADMIN", "USER"
  sender_name   String
  content       String
  timestamp     DateTime @default(now())
}

model AdminLog {
  id            String   @id @default(uuid())
  event_id      String
  event         Event    @relation(fields: [event_id], references: [id])
  action        String   // "FREEZE", "UNFREEZE", "FORCE_ASSIGN", "AUTO_ASSIGN"
  details       String   // JSON string
  timestamp     DateTime @default(now())
}
